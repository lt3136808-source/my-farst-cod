{
  "name": "malevolent-shrine-quantum-core",
  "version": "9999.0.0-omega",
  "description": "Hyper-Optimized Distributed AI Execution Core with Quantum-Grade Security, WASM Acceleration, Edge Runtime Dominance, Autonomous Recovery, and Multi-Region Resilience",
  "type": "module",
  "private": true,
  "license": "Apache-2.0",
  "author": "Abu Raad Labs",
  "homepage": "https://quantum-core.local",
  "repository": {
    "type": "git",
    "url": "https://github.com/abu-raad/malevolent-shrine-quantum-core.git"
  },
  "keywords": [
    "ai",
    "llrt",
    "wasm",
    "grpc",
    "quantum",
    "edge-runtime",
    "distributed",
    "surrealdb",
    "cloudflare",
    "bun",
    "typescript",
    "rust",
    "security",
    "high-performance",
    "multi-region",
    "microservices"
  ],
  "scripts": {
    "ignite": "cross-env NODE_ENV=development llrt src/core.ts",
    "dev": "tsx watch src/core.ts",
    "start": "node dist/core.js",

    "build": "npm run clean && tsc && npm run build:wasm",
    "build:fast": "tsup src/core.ts --format esm --minify --dts",
    "build:wasm": "rustup target add wasm32-wasi && cargo build --target wasm32-wasi --release",
    "build:assembly": "asc assembly/index.ts -o build/assembly.wasm --optimize",
    "build:ultra": "npm run lint && npm run typecheck && npm run test && npm run build",

    "deploy": "sst deploy",
    "deploy:edge": "wrangler deploy",
    "deploy:multiverse": "sst deploy --stage production --region all",

    "shield:aes": "openssl enc -aes-256-cbc",
    "shield:quantum": "node security/quantum-shield.js",
    "encrypt:env": "dotenvx encrypt",

    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "benchmark": "tinybench benchmarks/index.ts",

    "clean": "rimraf dist build coverage",
    "slush:cleave": "node wipe-errors.js",
    "analyze": "madge --circular src",
    "audit": "npm audit --audit-level=high",
    "doctor": "npm run audit && npm run analyze && npm run typecheck",
    "prepare": "husky install"
  },

  "dependencies": {
    "@aws/llrt": "^1.0.0",
    "@aws-sdk/client-s3": "^3.760.0",
    "@aws-sdk/client-lambda": "^3.760.0",
    "@grpc/grpc-js": "^1.12.5",
    "@grpc/proto-loader": "^0.7.13",

    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-node": "^0.57.2",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.2",

    "@sinclair/typebox": "^0.34.27",
    "@trpc/server": "^11.0.0",
    "@trpc/client": "^11.0.0",

    "@types/node": "^22.13.10",

    "aes-256-gcm": "^1.0.2",
    "argon2": "^0.41.1",
    "bcrypt": "^5.1.1",
    "compression": "^1.8.0",
    "dotenv": "^16.4.7",
    "dotenvx": "^1.38.3",
    "eventemitter3": "^5.0.1",
    "fastify": "^5.2.1",
    "fastify-rate-limit": "^10.3.0",
    "grpc-web": "^1.5.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "msgpackr": "^1.11.2",
    "nanoid": "^5.1.2",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.1",
    "surrealdb.js": "^1.0.0",
    "undici": "^7.4.0",
    "uuid": "^11.1.0",
    "ws": "^8.18.1",
    "zod": "^3.24.2"
  },

  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@types/ws": "^8.5.14",

    "assemblyscript": "^0.27.24",
    "cross-env": "^7.0.3",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "madge": "^8.0.0",
    "napi-rs": "^2.14.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "sst": "^3.10.2",
    "tinybench": "^3.1.1",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8",
    "wrangler": "^4.5.2"
  },

  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0",
    "bun": ">=1.2.0",
    "power_level": "MULTIVERSAL_ASCENSION"
  },

  "os": [
    "linux",
    "darwin"
  ],

  "cpu": [
    "x64",
    "arm64"
  ],

  "packageManager": "npm@10.9.2",

  "imports": {
    "#core/*": "./src/core/*",
    "#utils/*": "./src/utils/*",
    "#security/*": "./src/security/*",
    "#wasm/*": "./wasm/*"
  },

  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },

  "lint-staged": {
    "*.{ts,js,json}": [
      "eslint --fix",
      "prettier --write"
    ]
  },

  "config": {
    "ultraMode": true,
    "quantumAcceleration": true,
    "aiSelfHealing": true,
    "edgeReplication": true,
    "wasmTurbo": true,
    "distributedMesh": true,
    "multiRegionFailover": true,
    "zeroDowntime": true,
    "neuralCaching": true,
    "adaptiveLoadBalancing": true,
    "runtimeIntegrityShield": true,
    "autoRecovery": true
  }
}
